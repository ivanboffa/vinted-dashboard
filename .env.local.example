# Supabase PostgreSQL — transaction pooler (port 6543 required for Vercel serverless)
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# Shared dashboard password — give this to anyone who needs access
DASHBOARD_PASSWORD=change-this-password

# Session encryption key — MUST be 32+ random characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-at-least-32-random-chars
